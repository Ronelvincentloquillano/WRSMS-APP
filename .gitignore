ggproject/
my_env/
venv/
static/admin/
static/fontawesome/
static/js/jquery-3.7.1.min.js
static/js/popper.min.js
static/js/bootstrap*.*
static/css/bootstrap*.*
static/css/input.css
static/src/
static/icons/
staticfiles/
