# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/
dist/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# Gemini notes
session_notes.md

# Environment files
.env
.env.prod*
.env.local
.vscode/

# SQL and backup
*.backup
*.sqlite3

# Tailwind CSS generated files
# tailwind.config.js
package-lock.json
# package.json


